<% content_for :title, page_title("Contact") %>
<% content_for :meta_description, "Contact Baltimore.ai: corrections, additions, removals, and other directory matters." %>

<%= render "shared/breadcrumbs", crumbs: [ [ "Home", root_path ], [ "Contact", nil ] ] %>

<article class="max-w-2xl">
  <header class="border-b border-stone-200 pb-8 mb-8">
    <p class="text-xs uppercase tracking-[0.2em] text-red-700 font-semibold mb-3">Contact</p>
    <h1 class="text-4xl md:text-5xl font-black tracking-tight">Get in touch</h1>
    <p class="mt-3 text-lg text-stone-600">
      Corrections, additions, removals, press, anything else. Response within a few days.
    </p>
  </header>

  <% if notice = flash[:notice] %>
    <div class="mb-6 p-3 bg-emerald-50 text-emerald-800 border border-emerald-200 rounded-md text-sm"><%= notice %></div>
  <% end %>
  <% if flash[:alert] %>
    <div class="mb-6 p-3 bg-red-50 text-red-800 border border-red-200 rounded-md text-sm"><%= flash[:alert] %></div>
  <% end %>

  <%= form_with model: @contact_message, url: contact_messages_path, local: true, class: "space-y-5" do |f| %>
    <%# Honeypot: real users leave this blank %>
    <div style="position: absolute; left: -9999px;" aria-hidden="true">
      <label for="company_url">Company URL (leave blank)</label>
      <%= tag.input type: "text", name: "company_url", id: "company_url", tabindex: -1, autocomplete: "off" %>
    </div>

    <div>
      <%= f.label :name, "Your name", class: "block text-sm font-semibold text-stone-700 mb-1" %>
      <%= f.text_field :name, required: true, autocomplete: "name",
            class: "w-full px-3 py-2 border border-stone-300 rounded-md focus:border-stone-900 focus:outline-none" %>
    </div>
    <div>
      <%= f.label :email, "Email", class: "block text-sm font-semibold text-stone-700 mb-1" %>
      <%= f.email_field :email, required: true, autocomplete: "email",
            class: "w-full px-3 py-2 border border-stone-300 rounded-md focus:border-stone-900 focus:outline-none" %>
    </div>
    <div>
      <%= f.label :subject, "Subject", class: "block text-sm font-semibold text-stone-700 mb-1" %>
      <%= f.text_field :subject,
            class: "w-full px-3 py-2 border border-stone-300 rounded-md focus:border-stone-900 focus:outline-none",
            placeholder: "What's this about?" %>
    </div>
    <div>
      <%= f.label :body, "Message", class: "block text-sm font-semibold text-stone-700 mb-1" %>
      <%= f.text_area :body, rows: 6, required: true,
            class: "w-full px-3 py-2 border border-stone-300 rounded-md focus:border-stone-900 focus:outline-none",
            placeholder: "A few sentences..." %>
      <p class="text-xs text-stone-500 mt-1">Minimum 30 characters.</p>
    </div>
    <%= f.submit "Send message",
          class: "bg-stone-900 text-white px-5 py-2.5 rounded-md font-semibold hover:bg-stone-700" %>
  <% end %>
</article>
