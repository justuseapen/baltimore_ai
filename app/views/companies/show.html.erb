<% content_for :title, page_title(@company.name, "Baltimore AI directory") %>
<% content_for :meta_description, (@company.meta_description.presence || @company.tagline.presence || "#{@company.name} — a Baltimore-area #{category_label(@company.primary_category)} company on the Baltimore.ai directory.") %>
<% content_for :og_type, "article" %>

<%= render "shared/breadcrumbs", crumbs: [
  [ "Home", root_path ],
  [ "Companies", companies_path ],
  [ @company.name, nil ]
] %>

<article>
  <header class="border-b border-stone-200 pb-8 mb-8">
    <div class="flex items-baseline justify-between gap-4 flex-wrap">
      <div>
        <p class="text-xs uppercase tracking-[0.2em] text-red-700 font-semibold mb-2"><%= category_label(@company.primary_category) %></p>
        <h1 class="text-4xl md:text-5xl font-black tracking-tight text-stone-900"><%= @company.name %></h1>
        <% if @company.tagline.present? %>
          <p class="mt-3 text-xl text-stone-600 max-w-3xl"><%= @company.tagline %></p>
        <% end %>
      </div>
      <% if @company.claimed? %>
        <span class="text-xs uppercase tracking-wider px-2 py-1 bg-emerald-50 text-emerald-700 border border-emerald-200 rounded">Claimed</span>
      <% else %>
        <span class="text-xs uppercase tracking-wider px-2 py-1 bg-stone-50 text-stone-600 border border-stone-200 rounded">Unclaimed</span>
      <% end %>
    </div>

    <dl class="mt-6 grid grid-cols-2 md:grid-cols-4 gap-4 text-sm">
      <% if @company.founded_year %>
        <div>
          <dt class="text-xs uppercase tracking-wider text-stone-500">Founded</dt>
          <dd class="mt-1 font-semibold text-stone-900"><%= @company.founded_year %></dd>
        </div>
      <% end %>
      <% if @company.employee_count_bucket.present? %>
        <div>
          <dt class="text-xs uppercase tracking-wider text-stone-500">Team size</dt>
          <dd class="mt-1 font-semibold text-stone-900"><%= @company.employee_count_bucket %></dd>
        </div>
      <% end %>
      <div>
        <dt class="text-xs uppercase tracking-wider text-stone-500">Location</dt>
        <dd class="mt-1 font-semibold text-stone-900"><%= [ @company.city, @company.state ].compact_blank.join(", ") %></dd>
      </div>
      <% if @company.website.present? %>
        <div>
          <dt class="text-xs uppercase tracking-wider text-stone-500">Website</dt>
          <dd class="mt-1 font-semibold">
            <%= link_to @company.domain || @company.website, @company.website, class: "text-red-700 hover:underline", rel: "noopener", target: "_blank" %>
          </dd>
        </div>
      <% end %>
    </dl>
  </header>

  <% if @company.description.present? %>
    <div class="prose prose-stone max-w-3xl mb-10">
      <%= simple_format(@company.description) %>
    </div>
  <% end %>

  <% if @company.tags.any? %>
    <div class="mb-10">
      <h2 class="text-xs uppercase tracking-wider text-stone-500 mb-3">Tags</h2>
      <div class="flex flex-wrap gap-2">
        <% @company.tags.each do |tag| %>
          <span class="text-sm px-3 py-1 bg-white border border-stone-300 rounded-full text-stone-700"><%= tag.name %></span>
        <% end %>
      </div>
    </div>
  <% end %>

  <% links = {
       "Website" => @company.website,
       "LinkedIn" => @company.linkedin_url,
       "GitHub" => @company.github_url,
       "Crunchbase" => @company.crunchbase_url,
       "X / Twitter" => @company.twitter_url
     }.compact_blank %>
  <% if links.any? %>
    <div class="mb-10">
      <h2 class="text-xs uppercase tracking-wider text-stone-500 mb-3">Links</h2>
      <ul class="space-y-1">
        <% links.each do |label, url| %>
          <li>
            <span class="text-stone-500 inline-block w-24"><%= label %></span>
            <%= link_to url, url, class: "text-red-700 hover:underline", rel: "noopener", target: "_blank" %>
          </li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <% if @similar_companies.any? %>
    <aside class="mt-16 border-t border-stone-200 pt-8">
      <h2 class="text-xs uppercase tracking-wider text-stone-500 mb-4">Similar companies in <%= category_label(@company.primary_category) %></h2>
      <ul class="space-y-1">
        <% @similar_companies.each do |similar| %>
          <%= render "row", company: similar %>
        <% end %>
      </ul>
    </aside>
  <% end %>
</article>

<script type="application/ld+json">
<%=
  org = {
    "@context" => "https://schema.org",
    "@type" => "Organization",
    "name" => @company.name,
    "url" => @company.website,
    "description" => @company.description,
    "address" => {
      "@type" => "PostalAddress",
      "addressLocality" => @company.city,
      "addressRegion" => @company.state,
      "addressCountry" => @company.country
    }.compact,
    "sameAs" => [ @company.linkedin_url, @company.github_url, @company.crunchbase_url, @company.twitter_url ].compact_blank,
    "foundingDate" => @company.founded_year&.to_s
  }.compact
  raw org.to_json
%>
</script>
