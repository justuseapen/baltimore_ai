<!DOCTYPE html>
<html lang="en">
  <head>
    <title><%= content_for(:title) || "Baltimore.ai · The directory of AI in Baltimore" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="description" content="<%= content_for(:meta_description) || 'A curated directory of AI companies, research labs, and resources in the Baltimore metro.' %>">
    <meta name="theme-color" content="#0a0a0a">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="application-name" content="Baltimore.ai">
    <meta name="mobile-web-app-capable" content="yes">

    <link rel="canonical" href="<%= canonical_url %>">

    <meta property="og:type" content="<%= content_for(:og_type) || 'website' %>">
    <meta property="og:title" content="<%= content_for(:title) || 'Baltimore.ai' %>">
    <meta property="og:description" content="<%= content_for(:meta_description) || 'A curated directory of AI companies, research labs, and resources in the Baltimore metro.' %>">
    <meta property="og:url" content="<%= canonical_url %>">
    <meta property="og:site_name" content="Baltimore.ai">
    <meta property="og:image" content="<%= image_url('og-default.png') %>">
    <meta property="og:image:width" content="1200">
    <meta property="og:image:height" content="630">

    <meta name="twitter:card" content="summary_large_image">
    <meta name="twitter:title" content="<%= content_for(:title) || 'Baltimore.ai' %>">
    <meta name="twitter:description" content="<%= content_for(:meta_description) || 'A curated directory of AI companies, research labs, and resources in the Baltimore metro.' %>">
    <meta name="twitter:image" content="<%= image_url('og-default.png') %>">

    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%= yield :head %>

    <link rel="icon" href="/icon.png" type="image/png">
    <link rel="icon" href="/icon.svg" type="image/svg+xml">
    <link rel="apple-touch-icon" href="/icon.png">

    <%= stylesheet_link_tag :app, "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>

    <%= render "shared/site_jsonld" %>
  </head>

  <body class="bg-stone-50 text-stone-900 antialiased font-sans">
    <header class="border-b border-stone-200 bg-white">
      <div class="max-w-6xl mx-auto px-6 py-5 flex items-center justify-between">
        <%= link_to root_path, class: "flex items-baseline gap-1" do %>
          <span class="text-2xl font-black tracking-tight text-stone-900">baltimore</span>
          <span class="text-2xl font-black tracking-tight text-red-700">.ai</span>
        <% end %>
        <nav class="flex items-center gap-6 text-sm font-medium text-stone-600">
          <%= link_to "Companies", companies_path, class: "hover:text-stone-900" %>
          <%= link_to "Categories", categories_path, class: "hover:text-stone-900" %>
          <%= link_to "Guides", guides_path, class: "hover:text-stone-900" %>
          <%= link_to "Resources", resources_path, class: "hover:text-stone-900" %>
        </nav>
      </div>
    </header>

    <main class="max-w-6xl mx-auto px-6 py-10">
      <%= yield %>
    </main>

    <footer class="border-t border-stone-200 mt-24 bg-white">
      <div class="max-w-6xl mx-auto px-6 py-12">
        <div class="grid grid-cols-2 md:grid-cols-4 gap-8 text-sm">
          <div>
            <div class="font-semibold text-stone-900 mb-3">Directory</div>
            <ul class="space-y-2 text-stone-600">
              <li><%= link_to "Companies", companies_path, class: "hover:text-stone-900" %></li>
              <li><%= link_to "Categories", categories_path, class: "hover:text-stone-900" %></li>
              <li><%= link_to "Resources", resources_path, class: "hover:text-stone-900" %></li>
              <li><%= link_to "Guides", guides_path, class: "hover:text-stone-900" %></li>
            </ul>
          </div>
          <div>
            <div class="font-semibold text-stone-900 mb-3">About</div>
            <ul class="space-y-2 text-stone-600">
              <li><%= link_to "About", "/about", class: "hover:text-stone-900" %></li>
              <li><%= link_to "Editorial standards", editorial_standards_path, class: "hover:text-stone-900" %></li>
              <li><%= link_to "How it works", how_it_works_path, class: "hover:text-stone-900" %></li>
              <li><%= link_to "Contact", contact_path, class: "hover:text-stone-900" %></li>
            </ul>
          </div>
          <div>
            <div class="font-semibold text-stone-900 mb-3">For companies</div>
            <ul class="space-y-2 text-stone-600">
              <li><%= link_to "Sign in", sign_in_request_path, class: "hover:text-stone-900" %></li>
              <li><%= link_to "How it works", how_it_works_path, class: "hover:text-stone-900" %></li>
            </ul>
          </div>
          <div>
            <div class="font-semibold text-stone-900 mb-3">Legal</div>
            <ul class="space-y-2 text-stone-600">
              <li><%= link_to "Privacy", "/privacy", class: "hover:text-stone-900" %></li>
              <li><%= link_to "Terms", "/terms", class: "hover:text-stone-900" %></li>
            </ul>
          </div>
        </div>
        <div class="border-t border-stone-200 mt-10 pt-6 text-sm text-stone-500">
          <span class="font-semibold text-stone-700">Baltimore.ai</span> · The directory of AI in Baltimore. Curated by <a href="/about" class="hover:text-stone-900">Justus Eapen</a>.
        </div>
      </div>
    </footer>
  </body>
</html>
