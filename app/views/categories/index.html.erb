<% content_for :title, page_title("Categories") %>
<% content_for :meta_description, "Browse Baltimore AI companies by category — applied AI, healthcare AI, infrastructure, consulting, and more." %>

<%= render "shared/breadcrumbs", crumbs: [ [ "Home", root_path ], [ "Categories", nil ] ] %>

<header class="mb-10">
  <h1 class="text-4xl md:text-5xl font-black tracking-tight">Categories</h1>
  <p class="mt-3 text-lg text-stone-600">Browse Baltimore AI companies by what they do.</p>
</header>

<div class="grid grid-cols-1 md:grid-cols-2 gap-3">
  <% @categories.each do |slug| %>
    <% count = @counts[slug].to_i %>
    <%= link_to category_path(slug), class: "block p-5 bg-white border border-stone-200 rounded-md hover:border-stone-400 group" do %>
      <div class="flex items-baseline justify-between">
        <div class="font-semibold text-stone-900 group-hover:text-red-700"><%= category_label(slug) %></div>
        <div class="text-sm text-stone-500"><%= count %></div>
      </div>
    <% end %>
  <% end %>
</div>
