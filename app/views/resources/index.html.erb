<% content_for :title, page_title("Labs & resources") %>
<% content_for :meta_description, "Research labs, accelerators, and programs supporting AI in the Baltimore metro." %>

<%= render "shared/breadcrumbs", crumbs: [ [ "Home", root_path ], [ "Resources", nil ] ] %>

<header class="mb-10">
  <h1 class="text-4xl md:text-5xl font-black tracking-tight">Labs & resources</h1>
  <p class="mt-3 text-lg text-stone-600">The research labs, accelerators, and programs that anchor Baltimore's AI scene.</p>
</header>

<% Resource::TYPES.each do |type| %>
  <% items = @grouped[type] %>
  <% next unless items&.any? %>
  <section class="mb-10">
    <h2 class="text-xs uppercase tracking-wider text-stone-500 mb-3"><%= resource_type_label(type) %></h2>
    <div class="grid grid-cols-1 md:grid-cols-2 gap-x-8 gap-y-1">
      <% items.each do |resource| %>
        <%= link_to resource_path(resource), class: "block py-3 border-b border-stone-100 group" do %>
          <div class="font-semibold text-stone-900 group-hover:text-red-700"><%= resource.name %></div>
          <% if resource.tagline.present? %>
            <div class="text-sm text-stone-600 mt-1 line-clamp-1"><%= resource.tagline %></div>
          <% end %>
        <% end %>
      <% end %>
    </div>
  </section>
<% end %>
