<% content_for :title, page_title(@resource.name) %>
<% content_for :meta_description, (@resource.meta_description.presence || @resource.tagline.presence || "#{@resource.name} — a Baltimore AI #{resource_type_label(@resource.resource_type).downcase}.") %>
<% content_for :og_type, "article" %>

<%= render "shared/breadcrumbs", crumbs: [
  [ "Home", root_path ],
  [ "Resources", resources_path ],
  [ @resource.name, nil ]
] %>

<article>
  <header class="border-b border-stone-200 pb-8 mb-8">
    <p class="text-xs uppercase tracking-[0.2em] text-red-700 font-semibold mb-2"><%= resource_type_label(@resource.resource_type) %></p>
    <h1 class="text-4xl md:text-5xl font-black tracking-tight text-stone-900"><%= @resource.name %></h1>
    <% if @resource.tagline.present? %>
      <p class="mt-3 text-xl text-stone-600 max-w-3xl"><%= @resource.tagline %></p>
    <% end %>
  </header>

  <% if @resource.description.present? %>
    <div class="prose prose-stone max-w-3xl mb-10">
      <%= simple_format(@resource.description) %>
    </div>
  <% end %>

  <% if @resource.website.present? %>
    <div>
      <span class="text-stone-500">Website</span>
      <%= link_to @resource.website, @resource.website, class: "text-red-700 hover:underline ml-2", rel: "noopener", target: "_blank" %>
    </div>
  <% end %>
</article>

<script type="application/ld+json">
<%=
  ld = {
    "@context" => "https://schema.org",
    "@type" => "Organization",
    "name" => @resource.name,
    "url" => @resource.website,
    "description" => @resource.description,
    "foundingDate" => @resource.founded_year&.to_s
  }.compact
  raw ld.to_json
%>
</script>
